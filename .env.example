# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Amazon Bedrock — Nova 2 Model IDs ────────────────────────────────────────
# Full model reference: https://docs.aws.amazon.com/nova/latest/userguide/what-is-nova.html
BEDROCK_REGION=us-east-1

# ORCHESTRATOR & PLANNER → Nova 2 Pro
#   Best for: Complex multi-step reasoning, agentic task graph planning, long-range orchestration.
NOVA_PRO_MODEL_ID=us.amazon.nova-2-pro-v1:0

# RECOVERY AGENT → Nova 2 Lite
#   Best for: Fast, cost-effective structured JSON inference. 1M token context.
#   Used for failure diagnosis and self-healing selector resolution.
NOVA_LITE_MODEL_ID=us.amazon.nova-2-lite-v1:0

# VOICE GATEWAY → Nova 2 Sonic
#   Best for: Real-time speech-to-speech via bidirectional streaming. 300k context.
#   Handles 8KHz telephony, background noise, and natural interruptions natively.
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_SONIC_VOICE=tiffany

# MEMORY ENGINE → Nova 2 Multimodal Embeddings
#   Best for: Semantic RAG over task/workflow history (text, image, audio, video).
#   Dimension options: 256 | 384 | 1024 (default) | 3072 — higher = better recall, more cost.
NOVA_EMBEDDINGS_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
NOVA_EMBEDDING_DIMENSION=1024

# Nova Act — Python SDK (pip install nova-act)
# Drives browser-based UI automation with natural language instructions.
# Get API key at https://nova.amazon.com/act
NOVA_ACT_API_KEY=
NOVA_ACT_PYTHON_PATH=python3

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
VOICE_GATEWAY_PORT=3002
DASHBOARD_PORT=3000
AUTOMATION_RUNNER_URL=http://localhost:3003
MAX_CONCURRENT_AGENTS=4
TASK_TIMEOUT=30000
RETRY_LIMIT=3

# ── Database ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=operon-
OPENSEARCH_ENDPOINT=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
SESSION_SECRET=

# ── Connectors — Jira ─────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_PROJECT_KEY=

# ── Connectors — Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=general

# ── Connectors — Gmail ────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Connectors — HubSpot / Notion ─────────────────────────────────────────────
HUBSPOT_API_KEY=
NOTION_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your dashboard URL in production (e.g. https://your-app.vercel.app)
# Leave blank in development (all origins allowed)
CORS_ORIGIN=
