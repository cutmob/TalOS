# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Bedrock — Official Model IDs (docs.aws.amazon.com/bedrock)
BEDROCK_REGION=us-east-1
NOVA_LITE_MODEL_ID=amazon.nova-2-lite-v1:0
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_EMBEDDINGS_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
NOVA_EMBEDDING_DIMENSION=1024

# Nova Act — Python SDK (pip install nova-act)
# Get API key at https://nova.amazon.com/act
NOVA_ACT_API_KEY=
# Path to Python with nova-act installed
NOVA_ACT_PYTHON_PATH=python3

# Application
NODE_ENV=development
API_PORT=3001
VOICE_GATEWAY_PORT=3002
DASHBOARD_PORT=3000

# Database
DYNAMODB_TABLE_PREFIX=operon-
OPENSEARCH_ENDPOINT=

# Auth
JWT_SECRET=
SESSION_SECRET=

# Connectors — Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_PROJECT_KEY=

# Connectors — Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=general

# Connectors — Gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Connectors — HubSpot / Notion
HUBSPOT_API_KEY=
NOTION_API_KEY=

# CORS — set to your dashboard URL in production (e.g. https://your-app.vercel.app)
# Leave blank in development (all origins allowed)
CORS_ORIGIN=
